{
  "manifest_version": 3,
  "name": "Natively Companion",
  "version": "1.0.0",
  "description": "Official companion extension for Natively. Securely sends active tab content to your local workspace on demand.",
  "key": "",
  "minimum_chrome_version": "114",
  "permissions": ["activeTab", "scripting", "storage", "alarms", "tabs"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*", "ws://127.0.0.1/*"],
  "optional_host_permissions": [
    "https://leetcode.com/*",
    "https://leetcode.cn/*",
    "https://www.hackerrank.com/*",
    "https://app.codesignal.com/*",
    "https://app.coderpad.io/*",
    "https://coderpad.io/*",
    "https://app.codility.com/*",
    "https://www.hackerearth.com/*",
    "https://codeforces.com/*",
    "https://atcoder.jp/*",
    "https://www.codechef.com/*",
    "https://www.spoj.com/*",
    "https://www.topcoder.com/*",
    "https://www.geeksforgeeks.org/*",
    "https://practice.geeksforgeeks.org/*",
    "https://www.codewars.com/*",
    "https://www.algoexpert.io/*",
    "https://neetcode.io/*",
    "https://open.kattis.com/*",
    "https://dmoj.ca/*",
    "https://cses.fi/*",
    "https://onlinejudge.org/*",
    "http://www.usaco.org/*",
    "https://projecteuler.net/*",
    "https://adventofcode.com/*",
    "https://judge.beecrowd.com/*",
    "https://judge.u-aizu.ac.jp/*",
    "https://acm.timus.ru/*",
    "https://oj.uz/*",
    "https://www.acmicpc.net/*",
    "https://replit.com/*",
    "https://www.onlinegdb.com/*",
    "https://codesandbox.io/*",
    "https://stackblitz.com/*",
    "https://codepen.io/*",
    "https://jsfiddle.net/*",
    "https://glitch.com/*",
    "https://onecompiler.com/*",
    "https://www.jdoodle.com/*",
    "https://www.programiz.com/*",
    "https://paiza.io/*",
    "https://colab.research.google.com/*",
    "https://www.kaggle.com/*",
    "https://godbolt.org/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Natively — capture this page",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon_16x16.png",
      "32": "icons/icon_32x32.png"
    }
  },
  "icons": {
    "16": "icons/icon_16x16.png",
    "32": "icons/icon_32x32.png",
    "48": "icons/icon_64x64.png",
    "128": "icons/icon_128x128.png"
  }
}
